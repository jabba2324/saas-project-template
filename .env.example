# ────────────────────────────────────────────────────────────────────────────
# Auth.js v5
# Generate AUTH_SECRET with: openssl rand -base64 32
# ────────────────────────────────────────────────────────────────────────────
AUTH_SECRET=

# ────────────────────────────────────────────────────────────────────────────
# Vercel Postgres (Neon)
# These are auto-populated when you link a Postgres store in the Vercel dashboard.
# For local dev, copy from: vercel env pull .env.local
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ────────────────────────────────────────────────────────────────────────────
# Vercel Blob
# Auto-populated when you link a Blob store in the Vercel dashboard.
# For local dev, copy from: vercel env pull .env.local
# ────────────────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=
